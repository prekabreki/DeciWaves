*.core
*.bin
*.mpk
*.stream
oo2core_*.dll

# Subagent-driven-development scratch (briefs, reports, ledger, review packages)
/.superpowers/

# Python
__pycache__/
*.pyc
.venv/
.venv-asr/
venv/
*.egg-info/

# Build artifacts (python -m build output: sdist + wheel)
/dist/
/build/

